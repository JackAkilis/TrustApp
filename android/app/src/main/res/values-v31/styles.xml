<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash overrides -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Keep background consistent with existing launch_background -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <!-- Hide the icon shown by Android 12+ splash -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>

        <!-- Flutter's pre-12 window background -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>

